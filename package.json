{
  "name": "clever-automations",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "security-test": "turbo run security-test"
  },
  "overrides": {
    "react-native": {
      "scheduler": "$scheduler"
    }
  },
  "dependencies": {
    "scheduler": "0.24.0-canary-efb381bbf-20230505"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "eslint": "^8.57.1",
    "express": "^5.2.1",
    "prettier": "^3.4.0",
    "react-native": "^0.81.5",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
