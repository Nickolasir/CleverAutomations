# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Voice Pipeline - Tier 2 (DIRECT APIs - never route through OpenRouter)
DEEPGRAM_API_KEY=your-deepgram-api-key
GROQ_API_KEY=your-groq-api-key
CARTESIA_API_KEY=your-cartesia-api-key

# Voice Pipeline - Picovoice (local, but needs access key for SDK)
PICOVOICE_ACCESS_KEY=your-picovoice-key

# OpenRouter (NON-VOICE ONLY: background, analytics, fallback)
OPENROUTER_API_KEY=your-openrouter-api-key

# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_LONG_LIVED_TOKEN=your-ha-token

# App
NODE_ENV=development

# Kitchen Sub-Hub
KITCHEN_HUB_CAMERA_DEVICE=/dev/video0
SCAN_BUTTON_GPIO_PIN=17
LED_RING_GPIO_PIN=18

# Web Dashboard (Next.js requires NEXT_PUBLIC_ prefix for client-side env vars)
# Copy these to packages/web-dashboard/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# PII Encryption Master Key (256-bit, hex-encoded)
# Generate with: openssl rand -hex 32
# Must also be set as app.settings.pii_master_key in Supabase Database Settings
PII_MASTER_KEY=your-64-hex-char-master-key