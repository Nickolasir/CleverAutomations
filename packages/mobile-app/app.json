{
  "expo": {
    "name": "Clever Automations",
    "slug": "clever-automations",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#D4A843"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cleverautomations.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Clever Automations uses the microphone for voice commands to control your smart home devices."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D4A843"
      },
      "package": "com.cleverautomations.app",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "890f11f4-efca-4a72-bd33-8f20bb7036fd"
      }
    },
    "owner": "nickolasir"
  }
}
